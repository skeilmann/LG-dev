{% comment %}
  delivery-payment-info.liquid
  Renders a delivery & payment information card with two columns.
  Displayed on the product page below the description.

  Usage:
  {% render 'delivery-payment-info' %}
{% endcomment %}

<div class="delivery-payment-card">
  <div class="delivery-payment-card__col">
    <h3 class="delivery-payment-card__heading">{{ 'shipping.delivery_heading' | t | default: 'Доставка' }}</h3>
    <ul class="delivery-payment-card__list">
      <li>
        <span class="delivery-payment-card__highlight">{{ 'shipping.courier_service' | t | default: 'Курьерской службой' }}</span>
        {{ 'shipping.courier_details' | t | default: 'Nova Post по Молдове (1-3 дня), бесплатно от 1500 MDL;' }}
      </li>
      <li>
        {{ 'shipping.pickup_prefix' | t | default: 'Самовывоз с магазина' }}
        <span class="delivery-payment-card__highlight">{{ 'shipping.pickup_store' | t | default: 'VEV LUX SHOP' }}</span>
        {{ 'shipping.pickup_suffix' | t | default: 'в г. Бельцы;' }}
      </li>
      <li>
        {{ 'shipping.local_courier' | t | default: 'Курьером по г. Бельцы, бесплатно от 300 MDL;' }}
      </li>
      <li>
        {{ 'shipping.international' | t | default: 'Курьерской службой по Европе и странам ЕС.' }}
      </li>
    </ul>
  </div>
  <div class="delivery-payment-card__divider" aria-hidden="true"></div>
  <div class="delivery-payment-card__col">
    <h3 class="delivery-payment-card__heading">{{ 'shipping.payment_heading' | t | default: 'Оплата' }}</h3>
    <ul class="delivery-payment-card__list">
      <li>
        <span class="delivery-payment-card__highlight">{{ 'shipping.cash' | t | default: 'Наличкой' }}</span>
        {{ 'shipping.cash_details' | t | default: 'при получении;' }}
      </li>
      <li>
        {{ 'shipping.card_payment' | t | default: 'Картой при получении;' }}
      </li>
      <li>
        {{ 'shipping.invoice_prefix' | t | default: 'Перечисление по е-фактуре (' }}
        <span class="delivery-payment-card__highlight">{{ 'shipping.invoice_legal' | t | default: 'для юр. лиц' }}</span>{{ 'shipping.invoice_suffix' | t | default: ');' }}
      </li>
      <li>
        <span class="delivery-payment-card__highlight">{{ 'shipping.online_payment' | t | default: 'Онлайн-оплата' }}</span>.
      </li>
    </ul>
  </div>
</div>
