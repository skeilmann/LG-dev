      "type": "main-account",
      "settings": {
        "padding_top": 36,
        "padding_bottom": 36
      },
      "blocks": {
        "loyalty_points_block": {
          "type": "loyalty_points",
          "settings": {
            "heading": "My Rewards",
            "show_tier_progress": true,
