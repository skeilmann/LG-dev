            "columns_desktop": 3,
            "show_view_all": true,
            "image_ratio": "adapt",
            "show_vendor": false
          }
        },
        "account_details_block": {
          "type": "account_details",
          "settings": {
            "heading": "Account Details"
          }
        }
      },
      "block_order": [
        "loyalty_points_block",
        "order_history_block",
        "favorites_block",
        "account_details_block"
      ]
    }
  },
  "order": [
    "main"
