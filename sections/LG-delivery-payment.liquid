{%- comment -%}
  LG-delivery-payment.liquid
  Two-column delivery & payment info card with vertical divider.
  Bold text in richtext renders as pink highlight.
{%- endcomment -%}

{{ 'section-main-product.css' | asset_url | stylesheet_tag }}

{%- if section.settings.delivery_content != blank or section.settings.payment_content != blank -%}
  <div class="page-width section-{{ section.id }}-padding">
    <div class="delivery-payment-card">
      {%- if section.settings.delivery_content != blank -%}
        <div class="delivery-payment-card__col">
          <h3 class="delivery-payment-card__heading">{{ section.settings.delivery_heading }}</h3>
          <div class="delivery-payment-card__body rte">
            {{ section.settings.delivery_content }}
          </div>
        </div>
      {%- endif -%}
      {%- if section.settings.delivery_content != blank and section.settings.payment_content != blank -%}
        <div class="delivery-payment-card__divider" aria-hidden="true"></div>
      {%- endif -%}
      {%- if section.settings.payment_content != blank -%}
        <div class="delivery-payment-card__col">
          <h3 class="delivery-payment-card__heading">{{ section.settings.payment_heading }}</h3>
          <div class="delivery-payment-card__body rte">
            {{ section.settings.payment_content }}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Delivery & Payment",
  "tag": "section",
  "class": "section",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "delivery_heading",
      "default": "Доставка",
      "label": "Delivery heading"
    },
    {
      "type": "richtext",
      "id": "delivery_content",
      "default": "<p>Курьерской службой <b>Nova Post</b> по Молдове (1-3 дня), бесплатно от <b>1500 MDL</b>;</p><p>Самовывоз с магазина <b>VEV LUX SHOP</b> в г. Бельцы;</p><p>Курьером по г. Бельцы, бесплатно от <b>300 MDL</b>;</p><p>Курьерской службой по Европе и странам ЕС.</p>",
      "label": "Delivery content (bold text = pink)"
    },
    {
      "type": "text",
      "id": "payment_heading",
      "default": "Оплата",
      "label": "Payment heading"
    },
    {
      "type": "richtext",
      "id": "payment_content",
      "default": "<p>Наличкой при получении;</p><p>Картой при получении;</p><p>Перечисление по е-фактуре (<b>для юр. лиц</b>);</p><p><b>Онлайн-оплата</b>.</p>",
      "label": "Payment content (bold text = pink)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "templates": ["product"],
  "presets": [
    {
      "name": "Delivery & Payment"
    }
  ]
}
{% endschema %}
